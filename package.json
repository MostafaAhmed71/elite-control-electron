{
  "name": "control",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node scripts/dev-electron.cjs",
    "build": "vite build",
    "build:electron": "electron-vite build && electron-builder",
    "build:all": "electron-vite build && electron-builder --win",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.northelite.control",
    "productName": "Elite Control",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "win": {
      "icon": "public/Elite Control.ico",
      "target": [
        "nsis"
      ]
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "كنترول نخبة الشمال"
    },
    "extraResources": [
      {
        "from": "src/splash.html",
        "to": "splash.html"
      },
      {
        "from": "omr_engine",
        "to": "omr_engine",
        "filter": [
          "**/*",
          "!venv/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!debug_scans/**",
          "!temp_sheets_custom/**",
          "!*.pdf",
          "!*.png",
          "!*.jpg",
          "!*.jpeg"
        ]
      },
      {
        "from": "wppconnect-master",
        "to": "wppconnect-master",
        "filter": [
          "**/*",
          "!tokens/**"
        ]
      }
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "firebase": "^12.7.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "express": "^5.2.1",
    "globals": "^16.5.0",
    "http-proxy-middleware": "^3.0.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "5.4.14"
  }
}
